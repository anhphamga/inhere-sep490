# Rental business rules
# Số giờ trước ngày thuê bắt đầu → tự động đổi ProductInstance sang Reserved
# 24 = đổi trước 1 ngày (production); giảm xuống 0 để test ngay lập tức
HOURS_BEFORE_RESERVED=24
# Chu kỳ job AutoReserve (phút). Mặc định 60 nếu không khai báo. Dev: ví dụ 1 để quét mỗi phút
AUTO_RESERVE_INTERVAL_MINUTES=1
# Phí trễ mỗi ngày (VND) — ví dụ: 50000 = 50,000đ/ngày
LATE_FEE_MULTIPLIER=50000
# Số ngày trễ tối thiểu để áp phí phạt tự động
AUTO_PENALTY_LATE_DAYS=3
# Thời gian giữ chỗ đơn PendingDeposit (phút) — đồng thời là thời gian trước khi auto-cancel
# Production: 30-60 phút; để nhỏ (5) khi test để tái booking nhanh
PENDING_DEPOSIT_HOLD_MINUTES=5
# Số ngày thuê tối đa cho 1 đơn
MAX_RENTAL_DAYS=30

# Retry/timeout
CHATBOT_GROQ_TIMEOUT_MS=20000
CHATBOT_MAX_RETRIES=3
CHATBOT_RETRY_BASE_DELAY_MS=800
CHATBOT_EMBEDDING_PROVIDER=local
CHATBOT_LOCAL_EMBEDDING_DIM=384